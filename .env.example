# Navidrome Configuration
NAVIDROME_URL=http://navidrome:4533

# Use username/password (will login to get token)
NAVIDROME_USERNAME=your_navidrome_username
NAVIDROME_PASSWORD=your_password

# =============================================================================
# AI Configuration
# =============================================================================

# AI Provider Selection
# Options: openrouter, groq, google, ollama
AI_PROVIDER=google

# API Key (required for openrouter, groq, and google; not needed for ollama)
# - Get OpenRouter key: https://openrouter.ai/ ($5 minimum, pay-as-you-go and some free models)
# - Get Groq key: https://console.groq.com/ (FREE but low Token limit, no credit card required)
# - Get Google AI key: https://ai.google.dev/ (FREE, generous quota, no credit card required)
AI_API_KEY=your_api_key_here

# Model Selection
# Use a high tier Instruct or low to mid tier Reasoning Model
# OpenRouter: poolside/laguna-xs-2.1:free, nvidia/nemotron-3-super-120b-a12b:free, meta-llama/llama-3.3-70b-instruct, etc.
# Groq: llama-3.3-70b-versatile, openai/gpt-oss-120b, llama-3.1-8b-instant, etc. (for free tier lower playlist length to 25 Tracks)
# Google: gemini-3.5-flash, gemini-3.1-pro, gemini-2.5-flash, gemini-3.1-flash-lite, etc.
# Ollama: llamusic, llama3.2, mistral, mixtral, etc. (must be pulled first: ollama pull llamusic)
AI_MODEL=gemini-3.5-flash

# Description Model (optional - used only for Genre Mix and This is playlist descriptions)
# If empty, falls back to AI_MODEL. Uses the same provider and API key as AI_MODEL.
# Useful for offloading the cheap description step to a smaller/faster model.
# Use a small and cheap instruct model
# OpenRouter: nvidia/nemotron-nano-9b-v2:free, openrouter/free, etc.
# Groq: llama-3.1-8b-instant, openai/gpt-oss-20b, etc.
# Google: gemma-4-26b-a4b-it, gemma-4-31b-it, gemini-3.1-flash-lite, etc.
# Ollama: llama3.2, llamusic, mixtral, etc.
DESCRIPTION_AI_MODEL=gemma-4-26b-a4b-it

# Ollama Base URL (only needed if using ollama provider)
# - Running locally without Docker: http://localhost:11434/v1/chat/completions
# - MagicLists in Docker, Ollama on host: http://host.docker.internal:11434/v1/chat/completions
# - Both in same docker-compose: http://ollama:11434/v1/chat/completions
OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions

# Ollama Request Timeout (only needed if using ollama provider)
# Default: 180 seconds. Increase if you have a slow CPU or large models
# Examples: 300 (5 minutes), 600 (10 minutes), 900 (15 minutes)
OLLAMA_TIMEOUT=180

# Ollama Max Tracks
# Absolute maximum number of tracks to send to the LLM for curation.
# Overrides the dynamic threshold calculation to prevent oversized payloads.
# Only used for OLLAMA to reduce Input context length to avoid prompt truncating
# Recommended: 120-300 for most local models. Leave empty for dynamic threshold.
# 130 Tracks will be around 4096 tokens depending on used model and mode
OLLAMA_MAX_TRACKS=150

# Music Path (for Docker Compose)
MUSIC_PATH=/path/to/your/music/library

# Database Configuration
# For Docker: use /app/data/magiclists.db (mounted volume)
# For local development: use ./magiclists.db (current directory)
DATABASE_PATH=/app/data/magiclists.db

# Logging Configuration (ERROR=minimal, INFO=normal, DEBUG=verbose)
LOG_LEVEL=INFO

# Set the ID of the Navidrome library to use (optional)
# Leave empty to use the default library
NAVIDROME_LIBRARY_ID=